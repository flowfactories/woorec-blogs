{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "woorec-blogs",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
 // 静态资产配置 - 指向Hugo的输出目录
  "assets": {
    "directory": "./public",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": false
  },
  
  // 构建配置
  "build": {
    "command": "hugo --gc --minify"
  }
}
